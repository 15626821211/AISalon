# ========== 生产环境配置 ==========
# 复制此文件为 .env.production 并填入真实值

# Flask
SECRET_KEY=替换为随机字符串-至少32位
DEBUG=False

# MySQL (与 docker-compose 中的 MYSQL_ROOT_PASSWORD 一致)
MYSQL_ROOT_PASSWORD=AiSalon2026!
DATABASE_URL=mysql+pymysql://root:AiSalon2026!@mysql:3306/ai_salon

# Azure OpenAI
OPENAI_API_KEY=你的API密钥
OPENAI_BASE_URL=https://dmc-openai-swec.openai.azure.com/openai/v1
OPENAI_MODEL=gpt-4o

# GitHub (提升 API 速率限制)
GITHUB_TOKEN=ghp_你的token

# GitLab (私有仓库需要)
GITLAB_USERNAME=
GITLAB_PASSWORD=
# GITLAB_TOKEN=glpat-xxxx

# 邮件 (可选)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
